# Copy this file to .env and fill in the values before running the application.
# Never commit .env to version control.

# ─── Database ──────────────────────────────────────────────────────────────
DB_URL=jdbc:postgresql://localhost:5432/triage_db
DB_USERNAME=postgres
DB_PASSWORD=your_db_password_here

# ─── JWT ───────────────────────────────────────────────────────────────────
# Must be a Base64-encoded secret of at least 32 bytes.
# Generate one with: openssl rand -base64 32
JWT_SECRET=replace_with_base64_encoded_secret
JWT_EXPIRATION_MS=86400000

# ─── OpenAI ────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# ─── CORS ──────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (no trailing slashes)
CORS_ALLOWED_ORIGINS=http://localhost:3000
